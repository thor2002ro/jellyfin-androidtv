<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingStart="10dp"
    android:paddingTop="7dp"
    android:paddingEnd="10dp"
    android:paddingBottom="7dp"
    tools:layout_width="184dp">

    <org.jellyfin.androidtv.ui.AsyncImageView
        android:id="@+id/channelImage"
        android:layout_width="58dp"
        android:layout_height="38dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerInside" />

    <TextView
        android:id="@+id/channelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/channelImage"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:textColor="@color/white"
        android:textSize="14sp"
        tools:text="Channel" />

    <TextView
        android:id="@+id/channelNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/channelName"
        android:layout_alignStart="@id/channelName"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:textColor="@color/guide_text_secondary"
        android:textSize="12sp"
        tools:text="12.1" />

    <ImageView
        android:id="@+id/favImage"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_alignTop="@id/channelNumber"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/channelNumber"
        android:scaleType="centerInside"
        android:src="@drawable/ic_heart_red"
        android:visibility="gone" />
</RelativeLayout>
