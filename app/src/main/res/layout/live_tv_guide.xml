<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/live_tv_guide_background"
    android:paddingStart="28dp"
    android:paddingTop="22dp"
    android:paddingEnd="28dp"
    android:paddingBottom="20dp">

    <org.jellyfin.androidtv.ui.ClockUserView
        android:id="@+id/clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="2dp" />

    <org.jellyfin.androidtv.ui.AsyncImageView
        android:id="@+id/programImage"
        android:layout_width="184dp"
        android:layout_height="104dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="@drawable/guide_detail_image_background"
        android:padding="1dp"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/programImage"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="24dp"
        android:layout_toStartOf="@id/clock"
        android:layout_toEndOf="@id/programImage"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:textColor="@color/white"
        android:textSize="27sp"
        tools:text="Program title" />

    <LinearLayout
        android:id="@+id/infoRow"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_below="@id/title"
        android:layout_alignStart="@id/title"
        android:layout_alignEnd="@id/title"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/infoRow"
        android:layout_alignStart="@id/title"
        android:layout_toStartOf="@id/actionBar"
        android:layout_above="@id/timelineHScroller"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:lineSpacingExtra="1dp"
        android:maxLines="3"
        android:textColor="@color/guide_text_secondary"
        android:textSize="15sp"
        tools:text="Selected program overview appears here." />

    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_above="@id/timelineHScroller"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/resetButton"
            style="@style/Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/guide_toolbar_button"
            android:contentDescription="@string/lbl_today"
            android:padding="9dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_time"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/dateButton"
            style="@style/Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/guide_toolbar_button"
            android:padding="9dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_calendar" />

        <ImageButton
            android:id="@+id/filterButton"
            style="@style/Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/guide_toolbar_button"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_filter" />

        <ImageButton
            android:id="@+id/optionsButton"
            style="@style/Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/guide_toolbar_button"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_settings" />
    </LinearLayout>

    <TextView
        android:id="@+id/displayDate"
        android:layout_width="184dp"
        android:layout_height="38dp"
        android:layout_above="@id/channelScroller"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="6dp"
        android:background="@drawable/live_tv_guide_timeline"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textColor="@color/white"
        android:textSize="14sp"
        tools:text="Today" />

    <HorizontalScrollView
        android:id="@+id/timelineHScroller"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_above="@id/programVScroller"
        android:layout_alignStart="@id/programVScroller"
        android:layout_alignEnd="@id/programVScroller"
        android:layout_marginBottom="6dp"
        android:background="@drawable/live_tv_guide_timeline"
        android:clipToPadding="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:id="@+id/timeline"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <org.jellyfin.androidtv.ui.ObservableScrollView
        android:id="@+id/channelScroller"
        android:layout_width="184dp"
        android:layout_height="match_parent"
        android:layout_below="@id/programImage"
        android:layout_alignParentStart="true"
        android:layout_above="@id/channelsStatus"
        android:layout_marginTop="78dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/live_tv_guide_panel"
        android:clipToPadding="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="4dp">

        <LinearLayout
            android:id="@+id/channels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:orientation="vertical" />
    </org.jellyfin.androidtv.ui.ObservableScrollView>

    <org.jellyfin.androidtv.ui.ObservableScrollView
        android:id="@+id/programVScroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignTop="@id/channelScroller"
        android:layout_alignBottom="@id/channelScroller"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@id/channelScroller"
        android:background="@drawable/live_tv_guide_grid_background"
        android:clipToPadding="false"
        android:padding="4dp">

        <org.jellyfin.androidtv.ui.ObservableHorizontalScrollView
            android:id="@+id/programHScroller"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/programRows"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </org.jellyfin.androidtv.ui.ObservableHorizontalScrollView>
    </org.jellyfin.androidtv.ui.ObservableScrollView>

    <TextView
        android:id="@+id/channelsStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@id/channelScroller"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="6dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:textColor="@color/guide_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/filterStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignEnd="@id/programVScroller"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="6dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:gravity="end"
        android:maxLines="1"
        android:textColor="@color/guide_text_secondary"
        android:textSize="12sp" />

    <RelativeLayout
        android:id="@+id/spinner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_transparent"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/textView9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="220dp"
            android:text="@string/lbl_loading_elipses"
            android:textAppearance="?android:attr/textAppearanceLarge" />

        <ProgressBar
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/textView9"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="12dp" />
    </RelativeLayout>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/settingsFilters"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/settingsOptions"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</RelativeLayout>
