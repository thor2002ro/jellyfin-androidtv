<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingStart="10dp"
    android:paddingTop="7dp"
    android:paddingEnd="10dp"
    android:paddingBottom="7dp"
    tools:layout_width="260dp">

    <TextView
        android:id="@+id/programName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:ellipsize="end"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="@string/no_program_data"
        android:textColor="@color/white"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/infoRow"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:layout_below="@id/programName"
        android:layout_alignParentStart="true"
        android:layout_marginTop="4dp"
        android:divider="@drawable/blank10x10"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:showDividers="middle" />

    <ImageView
        android:id="@+id/recIndicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_alignTop="@id/infoRow"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/infoRow"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_record_series_red" />
</RelativeLayout>
