<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="@integer/button_fade_duration"
    android:exitFadeDuration="@integer/button_fade_duration">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="315"
                        android:centerColor="@color/lb_basic_card_info_bg_color"
                        android:endColor="@color/jellyfin_purple"
                        android:startColor="@color/jellyfin_blue"
                        android:type="linear" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/jellyfin_blue" />
                </shape>
            </item>
            <item android:bottom="52dp">
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="270"
                        android:endColor="@color/transparent"
                        android:startColor="#66FFFFFF"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="315"
                        android:centerColor="@color/lb_basic_card_info_bg_color"
                        android:endColor="@color/grey"
                        android:startColor="@color/grey_light"
                        android:type="linear" />
                </shape>
            </item>
            <item android:bottom="58dp">
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="270"
                        android:endColor="@color/transparent"
                        android:startColor="#26FFFFFF"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
