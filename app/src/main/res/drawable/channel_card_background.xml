<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="@integer/button_fade_duration"
    android:exitFadeDuration="@integer/button_fade_duration">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="315"
                        android:centerColor="@color/card_focus_gradient_center"
                        android:endColor="@color/card_focus_gradient_end"
                        android:startColor="@color/card_focus_gradient_start"
                        android:type="linear" />
                    <stroke
                        android:width="@dimen/card_focus_stroke_width"
                        android:color="@color/card_focus_stroke" />
                </shape>
            </item>
            <item android:bottom="52dp">
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="270"
                        android:endColor="@color/transparent"
                        android:startColor="@color/card_focus_sheen"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="315"
                        android:centerColor="@color/card_neutral_gradient_center"
                        android:endColor="@color/card_neutral_gradient_end"
                        android:startColor="@color/card_neutral_gradient_start"
                        android:type="linear" />
                </shape>
            </item>
            <item android:bottom="58dp">
                <shape android:shape="rectangle">
                    <corners android:radius="?attr/cardRounding" />
                    <gradient
                        android:angle="270"
                        android:endColor="@color/transparent"
                        android:startColor="@color/card_neutral_sheen"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
