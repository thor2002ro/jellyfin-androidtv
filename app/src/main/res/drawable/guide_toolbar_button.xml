<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="@integer/button_fade_duration"
    android:exitFadeDuration="@integer/button_fade_duration">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/guide_button_focused" />
            <stroke
                android:width="2dp"
                android:color="@color/white" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/guide_button_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/guide_grid_line" />
        </shape>
    </item>
</selector>
