<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="MissingTranslation">
    <string name="preference_libvlc_options">LibVLC options</string>
    <string name="preference_libvlc_options_description">VLC playback engine options. Startup changes apply to newly started playback.</string>
    <string name="preference_libvlc_restart_required">Applies to newly started playback.</string>
    <string name="preference_libvlc_decoder">Video decoder</string>
    <string name="preference_libvlc_decoder_description">Choose how LibVLC uses Android hardware video decoding.</string>
    <string name="preference_libvlc_decoder_automatic">Automatic</string>
    <string name="preference_libvlc_decoder_automatic_description">Let LibVLC choose the decoder mode.</string>
    <string name="preference_libvlc_decoder_disabled">Software</string>
    <string name="preference_libvlc_decoder_disabled_description">Disable hardware video decoding. Highest CPU use, useful as a compatibility fallback.</string>
    <string name="preference_libvlc_decoder_decoding">Hardware decoding</string>
    <string name="preference_libvlc_decoder_decoding_description">Use hardware decoding but disable direct rendering, matching VLC Android\'s decoding mode.</string>
    <string name="preference_libvlc_decoder_full">Full hardware acceleration</string>
    <string name="preference_libvlc_decoder_full_description">Use hardware decoding and direct rendering. Fastest path when the device decoder is reliable.</string>
    <string name="preference_libvlc_video_output">Video output</string>
    <string name="preference_libvlc_video_output_description">Choose the LibVLC video output path. Applies to newly started playback.</string>
    <string name="preference_libvlc_video_output_automatic">Automatic</string>
    <string name="preference_libvlc_video_output_automatic_description">Let LibVLC choose the video output.</string>
    <string name="preference_libvlc_video_output_opengl">OpenGL</string>
    <string name="preference_libvlc_video_output_opengl_description">Use VLC Android\'s OpenGL output path: gles2.</string>
    <string name="preference_libvlc_video_output_android_display">Android display</string>
    <string name="preference_libvlc_video_output_android_display_description">Use VLC Android\'s native Android display output path.</string>
    <string name="preference_libvlc_audio_output">Audio output</string>
    <string name="preference_libvlc_audio_output_description">Choose the LibVLC audio output path. Applies to newly started playback.</string>
    <string name="preference_libvlc_audio_output_aaudio">AAudio default</string>
    <string name="preference_libvlc_audio_output_aaudio_description">Use LibVLC\'s default AAudio output path on current Android devices.</string>
    <string name="preference_libvlc_audio_output_audiotrack">AudioTrack</string>
    <string name="preference_libvlc_audio_output_audiotrack_description">Force Android AudioTrack output.</string>
    <string name="preference_libvlc_audio_output_opensles">OpenSL ES</string>
    <string name="preference_libvlc_audio_output_opensles_description">Force OpenSL ES output for older-device compatibility.</string>
    <string name="preference_libvlc_replay_gain">Replay gain</string>
    <string name="preference_libvlc_replay_gain_description">Normalize audio loudness from replay gain metadata. Applies to newly started playback.</string>
    <string name="preference_libvlc_replay_gain_mode">Replay gain mode</string>
    <string name="preference_libvlc_replay_gain_mode_description">Choose how LibVLC applies replay gain metadata.</string>
    <string name="preference_libvlc_replay_gain_mode_track">Track</string>
    <string name="preference_libvlc_replay_gain_mode_track_description">Make tracks with replay gain metadata play at the same loudness.</string>
    <string name="preference_libvlc_replay_gain_mode_album">Album</string>
    <string name="preference_libvlc_replay_gain_mode_album_description">Keep relative loudness between tracks from the same album.</string>
    <string name="preference_libvlc_replay_gain_preamp">Replay gain preamp</string>
    <string name="preference_libvlc_replay_gain_default">Default replay gain</string>
    <string name="preference_libvlc_replay_gain_peak_protection">Replay gain peak protection</string>
    <string name="preference_libvlc_replay_gain_peak_protection_description">Protect against clipping when replay gain changes audio level.</string>
    <string name="preference_libvlc_deblocking">Deblocking filter</string>
    <string name="preference_libvlc_deblocking_description">Change the LibVLC avcodec skip-loop-filter setting.</string>
    <string name="preference_libvlc_deblocking_automatic">Automatic</string>
    <string name="preference_libvlc_deblocking_automatic_description">Use VLC Android\'s device-based deblocking default.</string>
    <string name="preference_libvlc_deblocking_full">Full deblocking</string>
    <string name="preference_libvlc_deblocking_full_description">Highest quality and slowest software decoding path.</string>
    <string name="preference_libvlc_deblocking_medium">Medium deblocking</string>
    <string name="preference_libvlc_deblocking_medium_description">Skip deblocking on non-reference frames.</string>
    <string name="preference_libvlc_deblocking_low">Low deblocking</string>
    <string name="preference_libvlc_deblocking_low_description">Skip deblocking on non-key frames.</string>
    <string name="preference_libvlc_deblocking_none">No deblocking</string>
    <string name="preference_libvlc_deblocking_none_description">Fastest software decoding path. Can lower video quality.</string>
    <string name="preference_libvlc_frame_skip">Frame skip</string>
    <string name="preference_libvlc_frame_skip_description">Speed up decoding with VLC Android\'s skip-frame and skip-idct options. Can lower video quality.</string>
    <string name="preference_libvlc_audio_time_stretch">Time-stretching audio</string>
    <string name="preference_libvlc_audio_time_stretch_description">Speed up and slow down audio without changing pitch. Requires more CPU.</string>
    <string name="preference_libvlc_dav1d_thread_frames">Dav1d frame threads</string>
    <string name="preference_libvlc_value_auto">Auto</string>
</resources>
